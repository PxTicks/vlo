{
  "version": 1,
  "mask_cropping": {
    "mode": "crop"
  },
  "nodes": {
    "1": {
      "node_title": "Source video options",
      "widgets": {
        "__derived_mask_video_treatment": {
          "label": "Transparency handling",
          "value_type": "enum",
          "default": "Keep transparency",
          "options": [
            "Keep transparency",
            "Fill transparent with neutral gray",
            "Remove transparency"
          ],
          "frontend_only": true
        }
      }
    },
    "2": {
      "binary_derived_mask_of": "1"
    }
  },
  "aspect_ratio_processing": {
    "enabled": true,
    "stride": 16,
    "resolutions": [480, 720],
    "search_steps": 2,
    "target_nodes": [
      {
        "node_id": "7",
        "width_param": "resize_type.width",
        "height_param": "resize_type.height"
      }
    ],
    "postprocess": {
      "enabled": true,
      "mode": "stretch_exact",
      "apply_to": "all_visual_outputs"
    }
  }
}
